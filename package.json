{
  "name": "ai-financial-assistant",
  "version": "1.0.0",
  "description": "AI Personal Financial Assistant powered by OpenClaw",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts",
    "test": "node --loader ts-node/esm scripts/run-all-tests.ts",
    "build": "tsc -p tsconfig.build.json",
    "collect": "node ./dist/index.js -- --collect",
    "data": "node ./dist/index.js -- data",
    "options": "node ./dist/index.js -- options",
    "news": "node ./dist/index.js -- news",
    "analyze": "node --loader ts-node/esm src/index.ts analyze",
    "market": "node --loader ts-node/esm src/index.ts market",
    "trade": "node --loader ts-node/esm src/index.ts trade",
    "update-docs": "node --loader ts-node/esm scripts/update-agents-doc.ts",
    "eval:run": "node --loader ts-node/esm scripts/eval-runner.ts",
    "eval:compare": "node --loader ts-node/esm scripts/eval-compare.ts",
    "eval": "sh -c 'TS=$(date +\"%Y-%m-%d-%H-%M-%S\") && if [ -z \"$1\" ]; then npm run eval:run -- --timestamp $TS && npm run eval:compare -- --timestamp $TS; else npm run eval:run -- --timestamp $TS --dir \"$1\" && npm run eval:compare -- --timestamp $TS --dir \"$1\"; fi' --",
    "view": "npx tsx eval-view.ts",
    "claw-dev": "npx cpx2 \"src/agents/**/*\" ~/.openclaw --watch --ignore=\"**/templates/**\" & npx cpx2 \"src/agents/**/*\" /Users/taotanming/.openclaw-dev --watch --ignore=\"**/templates/**\""
  },
  "keywords": [
    "ai",
    "finance",
    "agent",
    "trading"
  ],
  "author": "OpenClaw User",
  "license": "ISC",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "dotenv": "^16.4.0",
    "fast-xml-parser": "^4.3.0",
    "inquirer": "^8.2.6",
    "rettiwt-api": "^6.2.1",
    "rss-parser": "^3.13.0",
    "technicalindicators": "^3.1.0",
    "uuid": "^9.0.0",
    "yahoo-finance2": "^3.13.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.0.0-rc.10",
    "@types/inquirer": "^9.0.3",
    "@types/node": "^20.5.0",
    "@types/uuid": "^9.0.2",
    "cpx2": "^8.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^5.4.21"
  }
}
