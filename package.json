{
  "name": "fincrew",
  "version": "1.0.0",
  "description": "A self-evolving multi-agent financial assistant powered by OpenClaw",
  "type": "module",
  "scripts": {
    "data": "npx tsx packages/tools/getStockData/cli.ts",
    "news": "npx tsx packages/tools/getNews/cli.ts",
    "kol": "npx tsx packages/tools/getKolOptions/cli.ts",
    "options": "npx tsx packages/tools/getOptions/cli.ts",
    "eval:run": "bash scripts/eval.sh run",
    "eval:compare": "bash scripts/eval.sh compare",
    "eval": "bash scripts/eval.sh zh",
    "eval:zh": "bash scripts/eval.sh zh",
    "eval:en": "bash scripts/eval.sh en",
    "view": "npx tsx packages/eval-ui/eval-view.ts",
    "deploy:dev": "bash scripts/deploy.sh --env dev",
    "deploy:prod": "bash scripts/deploy.sh --env prod",
    "deploy:watch": "bash scripts/deploy-watch.sh",
    "update-docs": "node --loader ts-node/esm scripts/update-agents-doc.ts"
  },
  "keywords": [
    "ai",
    "multi-agent",
    "financial",
    "openclaw",
    "trading",
    "stock-analysis"
  ],
  "author": "OpenClaw User",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "dotenv": "^16.4.0",
    "fast-xml-parser": "^4.3.0",
    "inquirer": "^8.2.6",
    "rettiwt-api": "^6.2.1",
    "rss-parser": "^3.13.0",
    "technicalindicators": "^3.1.0",
    "uuid": "^9.0.0",
    "yahoo-finance2": "^3.13.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.0.0-rc.10",
    "@types/inquirer": "^9.0.3",
    "@types/node": "^20.5.0",
    "@types/uuid": "^9.0.2",
    "cpx2": "^8.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^5.4.21"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/user/fincrew.git"
  }
}
