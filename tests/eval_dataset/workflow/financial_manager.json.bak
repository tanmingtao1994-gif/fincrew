    }
  },
  {
    "test_id": "fm_workflow_consensus",
    "agent_target": "workspace-financial-manager",
    "input_prompt": "我想买入MSFT，但我想确认一下宏观面、技术面都支持这个决策。请帮我做全面验证。",
    "expected_behavior": {
      "must_dispatch": [
        "info-processor",
        "macro-analyst",
        "technical-analyst"
      ],
      "must_contain": [
        "MSFT"
      ],
      "llm_judge": "1. 助手理解用户想要多维度验证买入决策。2. 助手调度了 info-processor、macro-analyst、technical-analyst 三个子 Agent。3. 助手明确展示了各个维度的判断：(a)宏观面是否支持 (b)技术面是否支持 (c)基本面是否支持。4. 如果三个维度不一致（如宏观面偏空但技术面有支撑），助手应该明确指出分歧。5. 最终结论综合考虑了所有维度，并给出了综合置信度。6. 如果不支持买入，助手应该给出替代建议（如等待、观望条件）。"
    }
  }
